# YaO Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Agent Backend ---
# Which backend to use for subagent invocations.
# Options: "python_only" (default, no API key needed), "anthropic_api" (requires API key)
# YAO_AGENT_BACKEND=python_only

# --- Anthropic API ---
# Required when YAO_AGENT_BACKEND=anthropic_api
# Get your key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-api03-...

# --- LLM Model ---
# Override the model used by AnthropicAPIBackend.
# Default: claude-sonnet-4-6
# YAO_LLM_MODEL=claude-sonnet-4-6
